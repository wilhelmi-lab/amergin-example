# Benchmark data — local-only.
# Local runs of `amergin run` write here. CI runs redirect storage to a
# sibling data repo (wilhelmi-lab/amergin-example-data) via the
# AMERGIN_STORAGE__BENCHMARK_DATA env var, so this dir is never
# committed in either workflow.
benchmark-data/

# Generated by `amergin evaluate`; commit only if you want the
# Level 2 dispatch priorities to be checked in.
amergin.priorities.toml
